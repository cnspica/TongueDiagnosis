# ==============================================================
# TongueDiagnosis AI - 环境变量配置模板
# 使用方法：复制此文件为 .env，填入真实值后启动后端
#   cp .env.example .env
# ==============================================================

# ---------------------------------------------------------------
# JWT 鉴权密钥（生产环境必须设置！否则每次重启 Token 全部失效）
# 生成随机密钥：python -c "import secrets; print(secrets.token_hex(64))"
# ---------------------------------------------------------------
JWT_SECRET_KEY=your-secure-random-key-at-least-64-chars

# ---------------------------------------------------------------
# LLM 后端选择
#   "openai_compatible"  — 使用在线 OpenAI 兼容 API（StepFun、DeepSeek、OpenAI 等）
#   "ollama"             — 使用本地 Ollama 模型
# ---------------------------------------------------------------
LLM_BACKEND=openai_compatible

# ---------------------------------------------------------------
# OpenAI 兼容 API（LLM_BACKEND=openai_compatible 时生效）
# 阶跃星辰 StepFun：https://platform.stepfun.com/
# ---------------------------------------------------------------
OPENAI_API_BASE=https://chatapi.stepfun.com/chatapi/v1
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=step-3.5-flash

# ---------------------------------------------------------------
# Ollama 本地模型（LLM_BACKEND=ollama 时生效）
# ---------------------------------------------------------------
OLLAMA_PATH=http://localhost:11434/api/chat
LLM_NAME=qwen3:8b

# ---------------------------------------------------------------
# 后端服务配置
# ---------------------------------------------------------------
APP_PORT=5000

# ---------------------------------------------------------------
# CORS 允许的前端域名（逗号分隔，生产环境务必修改！）
# ---------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
